# 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# ===== 数据库配置 =====
POSTGRES_USER=apihub
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=apihub
DATABASE_URL=postgres://apihub:your_strong_password_here@postgres:5432/apihub

# ===== Redis 配置 =====
REDIS_URL=redis://redis:6379

# ===== 安全配置 =====
# JWT 密钥（至少 32 字符）
JWT_SECRET=your-jwt-secret-at-least-32-characters

# 主密钥（用于加密 API Key，至少 32 字符）
MASTER_KEY=your-master-key-at-least-32-characters

# ===== 服务器配置 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# ===== 域名配置（用于自动 HTTPS）=====
# 如果使用 Caddy 自动 HTTPS，设置你的域名
# DOMAIN=apihub.yourdomain.com

# ===== 日志配置 =====
RUST_LOG=info

# ===== 开发配置 =====
# 仅在开发环境启用
# CORS_ALLOW_ORIGIN=http://localhost:5173
